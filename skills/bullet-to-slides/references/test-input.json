    {
      "type": "section",
      "title": "Going Deeper",
      "number": 2
    },
    {
      "type": "content",
      "title": "Practices for the Shaky Ground",
      "body": [
        {
          "kind": "bullet",
          "text": "**Name** the sensation before interpreting it",
          "animate": false,
          "refs": null,
          "children": []
        },
        {
          "kind": "bullet",
          "text": "Ask: *what would I need to believe for this to feel true?*",
          "animate": false,
          "refs": null,
          "children": []
        },
        {
          "kind": "bullet",
          "text": "Hold the question longer than is comfortable",
          "animate": false,
          "refs": [2],
          "children": [
            {
              "kind": "bullet",
              "text": "Comfort is often a sign you've stopped too soon",
              "animate": false,
              "refs": null,
              "children": []
            }
          ]
        }
      ],
      "references": [
        { "id": 2, "text": "https://example.com/inquiry", "isUrl": true }
      ],
      "continuation": null
    },
    {
      "type": "content",
      "title": "Summary",
      "body": [
        {
          "kind": "bullet",
          "text": "Self-doubt is information, not verdict",
          "animate": false,
          "refs": null,
          "children": []
        },
        {
          "kind": "bullet",
          "text": "The **quality of your questions** determines what you find",
          "animate": false,
          "refs": null,
          "children": []
        },
        {
          "kind": "bullet",
          "text": "Going deeper requires `courage`, not just method",
          "animate": false,
          "refs": null,
          "children": []
        }
      ],
